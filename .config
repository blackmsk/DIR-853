# 대상 기기 설정 (D-Link DIR-853 A1)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_dlink_dir-853-a1=y

# 무선 드라이버 (우리가 패치할 mt7615 엔진)
CONFIG_PACKAGE_kmod-mt7615e=y
CONFIG_PACKAGE_kmod-mt7615-common=y
CONFIG_PACKAGE_kmod-mt76-core=y

# 관리 화면 (LuCI) 및 기본 언어 설정
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-i18n-base-ko=y

# 성능 및 안정성을 위한 필수 라이브러리
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_ca-bundle=y
